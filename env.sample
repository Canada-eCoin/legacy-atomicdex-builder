# ──────────────────────────────────────────────────────────────────────────────
# pipeline-v1 — environment variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy to .env and customize:  cp env.sample .env
# All vars have sensible defaults — only set what you need to override.
#
# The build scripts (build-linux.sh, build-mac.sh, build-mac-intel.sh,
# build-mac-arm.sh, build-windows.ps1)
# read these ENV vars. For any var also defined in config/sources.json,
# the ENV var takes precedence over the config file.
# If neither ENV var nor config file provides a value, the hardcoded default
# (documented below) is used.
# ──────────────────────────────────────────────────────────────────────────────

# ── Consent ──────────────────────────────────────────────────────────────────
# Skip all "[Y/n]" prompts. Equivalent to --yes / -Yes flag.
# Set to 1 to auto-approve all dependency installs and confirmations.
# Default: unset (prompts will appear).
BUILD_YES=1

# ── CPU ──────────────────────────────────────────────────────────────────────
# CPU cores for compile. Lower = less system load, slower build.
# Higher = faster build, more RAM + thermal pressure.
# Default (unset): auto — Linux uses 1/3 of available cores,
#   macOS uses 1/2 (Thermal pressure), Windows uses 1/2.
# When to change: slow machine (set 1), dedicated build server (set all cores),
#   or running builds in background while working (keep low).
BUILD_CPUS=2

# ── Paths ────────────────────────────────────────────────────────────────────
# Where build artifacts land (binaries, AppImages, .app bundles).
# Default (unset): ./output/<platform>  (e.g. ./output/linux/)
# When to change: CI puts artifacts in a shared volume, or you want builds
#   from multiple checkouts to share an output directory.
OUTPUT_DIR=./output

# Where build logs go. Each run appends to logs/<platform>/build.log.
# Default (unset): ./logs/<platform>
# When to change: centralized logging directory, or /tmp for ephemeral builds.
LOG_DIR=./logs

# Where source repos are cloned and compiled.
# Default (unset): ./.build
# When to change: you want build cache on a faster disk, or /tmp for CI.
BUILD_DIR=./.build

# Where install.sh puts binaries.
# Default (unset): ~/.local  ($HOME/.local/bin/)
# When to change: system-wide install (/usr/local), or a custom prefix.
INSTALL_PREFIX=~/.local

# ── Source pins (override config/sources.json) ───────────────────────────────
# Repository and commit for the KDF engine (komodo-defi-framework).
# Overrides values in config/sources.json.
# Default (unset): read from config/sources.json
# When to change: testing a different fork, pinning a specific commit for
#   reproducible CI, or building from a local mirror.
KDF_REPO=https://github.com/KomodoPlatform/komodo-defi-framework
KDF_COMMIT=30c877c5

# Repository and commit for the desktop wallet.
# Overrides values in config/sources.json.
# Default (unset): read from config/sources.json
DESKTOP_REPO=https://github.com/cipig/komodo-wallet-desktop
DESKTOP_COMMIT=0d333c5

# ── Reproducible builds ──────────────────────────────────────────────────────
# Unix timestamp for deterministic byte-identical output.
# Set to a fixed timestamp (e.g. git commit timestamp) to produce the same
# binary every time. Unset = use current time (builds will differ).
# Default (unset): current time at build start.
# When to change: reproducible CI, release engineering, audit trails.
# SOURCE_DATE_EPOCH=1748390400



# ── macOS (build-mac*.sh only) ───────────────────────────────────────────────
# Required for code signing and notarization. Used by the mac build scripts.
# Leave unset for local/unsigned builds.
# Default (unset): no signing, no notarization.
# When to change: distributing signed .app bundles outside the App Store.
# APPLE_TEAM_ID=YOUR_TEAM_ID
# APPLE_DEVELOPER_ID="Developer ID Application: Your Name (TEAMID)"

# ── Windows cross-compile (build-windows.ps1 only) ───────────────────────────
# Rust target triple for KDF engine on Windows.
# Overrides auto-detection (MSVC vs MinGW).
# Default (unset): auto-detect — x86_64-pc-windows-msvc if MSVC found,
#   otherwise x86_64-pc-windows-gnu.
# When to change: forcing MinGW target on an MSVC system, or cross-compiling
#   for a different Windows ABI.
# KDF_TARGET=x86_64-pc-windows-gnu

# ── Docker (legacy) ──────────────────────────────────────────────────────────
# Override docker-compose binary name. Only used if you invoke the legacy
# Docker-based build path (not the native scripts).
# Default (unset): docker-compose
# DOCKER_COMPOSE=docker-compose
